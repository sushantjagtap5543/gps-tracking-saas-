# ==========================================
# ENTERPRISE GPS TRACKING PLATFORM
# Environment Configuration
# ==========================================

# Node Environment
NODE_ENV=development
PORT=5000

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=gps_admin
DB_PASSWORD=secure_password_change_this
DB_NAME=gps_tracking

# ==========================================
# CACHE (Redis)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# JWT & SECURITY
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_long_and_random
JWT_EXPIRE=24h

# ==========================================
# PAYMENT GATEWAY (Stripe)
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# ==========================================
# EMAIL SERVICE (Nodemailer)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@gpstracking.com

# ==========================================
# SMS SERVICE (Twilio)
# ==========================================
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# FRONTEND URLs
# ==========================================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# ==========================================
# ADMIN EMAIL
# ==========================================
ADMIN_EMAIL=admin@gpstracking.com

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==========================================
# SUBSCRIPTION DEFAULTS
# ==========================================
SUBSCRIPTION_MONTHLY_PRICE=29.99
SUBSCRIPTION_QUARTERLY_PRICE=79.99
SUBSCRIPTION_YEARLY_PRICE=249.99

# ==========================================
# ALERT CONFIGURATION
# ==========================================
SPEED_LIMIT_ALERT=120
GEOFENCE_ALERT_ENABLED=true
ROUTE_DEVIATION_TOLERANCE=50

# ==========================================
# ENCRYPTION
# ==========================================
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# ==========================================
# NOTIFICATIONS
# ==========================================
PUSH_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_ENABLED=true
SMS_NOTIFICATION_ENABLED=true

# ==========================================
# AWS S3 (Optional for backups/reports)
# ==========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=gps-tracking-bucket
