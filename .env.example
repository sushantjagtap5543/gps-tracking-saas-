# ==========================================
# ENTERPRISE GPS TRACKING PLATFORM
# ==========================================

# -----------------------------
# NODE
# -----------------------------
NODE_ENV=production
PORT=5000

# -----------------------------
# DATABASE (PostgreSQL - Docker Required Variables)
# -----------------------------
POSTGRES_USER=gps_admin
POSTGRES_PASSWORD=SecurePass123
POSTGRES_DB=gps_tracking

DB_HOST=postgres
DB_PORT=5432
DB_USER=gps_admin
DB_PASSWORD=SecurePass123
DB_NAME=gps_tracking

# Full connection string for backend
DATABASE_URL=postgresql://gps_admin:SecurePass123@postgres:5432/gps_tracking

# -----------------------------
# REDIS
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# -----------------------------
# JWT
# -----------------------------
JWT_SECRET=yeqZMasegqNfyA2m7raUBGsZRDrM2uM4F1VWORMdN5JC6JwleAG8NSo4jGPxBb3c
JWT_EXPIRE=24h

# -----------------------------
# STRIPE
# -----------------------------
STRIPE_SECRET_KEY=sk_test_replace_this
STRIPE_PUBLIC_KEY=pk_test_replace_this

# -----------------------------
# EMAIL
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@gpstracking.com

# -----------------------------
# TWILIO
# -----------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------
# FRONTEND (IMPORTANT: CHANGE AFTER DOMAIN SETUP)
# -----------------------------
REACT_APP_API_URL=http://YOUR_PUBLIC_IP/api
REACT_APP_SOCKET_URL=http://YOUR_PUBLIC_IP

# -----------------------------
# ADMIN
# -----------------------------
ADMIN_EMAIL=admin@gpstracking.com

# -----------------------------
# LOGGING
# -----------------------------
LOG_LEVEL=info

# -----------------------------
# CORS
# -----------------------------
CORS_ORIGIN=http://YOUR_PUBLIC_IP

# -----------------------------
# SUBSCRIPTION
# -----------------------------
SUBSCRIPTION_MONTHLY_PRICE=29.99
SUBSCRIPTION_QUARTERLY_PRICE=79.99
SUBSCRIPTION_YEARLY_PRICE=249.99

# -----------------------------
# ALERTS
# -----------------------------
SPEED_LIMIT_ALERT=120
GEOFENCE_ALERT_ENABLED=true
ROUTE_DEVIATION_TOLERANCE=50

# -----------------------------
# ENCRYPTION
# -----------------------------
ENCRYPTION_KEY=ReplaceWithVeryStrongEncryptionKey_ChangeInProduction

# -----------------------------
# NOTIFICATIONS
# -----------------------------
PUSH_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_ENABLED=true
SMS_NOTIFICATION_ENABLED=true

# -----------------------------
# AWS S3
# -----------------------------
AWS_ACCESS_KEY_ID=replace_this
AWS_SECRET_ACCESS_KEY=replace_this
AWS_REGION=us-east-1
AWS_S3_BUCKET=gps-tracking-bucket
